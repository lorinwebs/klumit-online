    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.39.0",
    "@vercel/analytics": "^1.6.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^10.16.5",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "posthog-js": "^1.404.1",
    "posthog-node": "^5.45.2",
